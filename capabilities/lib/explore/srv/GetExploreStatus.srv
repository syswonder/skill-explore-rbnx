# robonix/skill/explore/status — poll an exploration task's progress.
# Empty run_id means "the most recent task" so callers don't need to
# track ids if they only run one explore at a time.
string run_id
---
bool known                  # false if no task with that id
string state                # PENDING | RUNNING | SUCCEEDED | FAILED | CANCELED | TIMEOUT
float32 area_m2             # mapped free area so far
int32 frontiers_left        # frontier clusters above min_size threshold
float32 elapsed_s
float32 eta_s               # estimated seconds until done; -1 unknown
string detail               # human-readable
